void setup() {
  Serial.begin(9600);

  pinMode(LED1, OUTPUT);
  pinMode(LED2, OUTPUT);
  pinMode(LED3, OUTPUT);
  pinMode(BTN, INPUT_PULLUP);

  pinMode(SS1, OUTPUT);
  pinMode(SS2, OUTPUT);
  pinMode(SS3, OUTPUT);

  digitalWrite(SS1, HIGH);
  digitalWrite(SS2, HIGH);
  digitalWrite(SS3, HIGH);

  SPI.begin();

  r1.PCD_Init();
  r2.PCD_Init();
  r3.PCD_Init();

  u8g2.begin();

  mp3Serial.begin(9600);
  delay(1500);

  if (player.begin(mp3Serial)) {
    player.volume(25);
    Serial.println(F("DF OK"));
  } else {
    Serial.println(F("DF ERR"));
  }

  showBitmap(epd_bitmap_start);
	//player.play(SOUND_START);
}

void loop() {
  handleButton();

  if (state == SCANNING) {
    scanReader(r1, SS1, card1, size1, has1, LED1, 1);
    scanReader(r2, SS2, card2, size2, has2, LED2, 2);
    scanReader(r3, SS3, card3, size3, has3, LED3, 3);
  }
}

void handleButton() {
  bool btn = digitalRead(BTN);

  if (lastBtn == HIGH && btn == LOW) {
    delay(50);

    if (digitalRead(BTN) == LOW) {
      if (state == IDLE || state == RESULT) {
        startRound();
      } else if (state == SCANNING) {
        checkCards();
      }
    }
  }

  lastBtn = btn;
}

void startRound() {
  state = IDLE;   // σταματάει τελείως το scanning όσο μιλάει

  clearStoredCards();

  digitalWrite(LED1, LOW);
  digitalWrite(LED2, LOW);
  digitalWrite(LED3, LOW);

  showCurrentQuestion();

  delay(300);

  // if (currentQuestion == 0) player.play(SOUND_TEETH);
  // if (currentQuestion == 1) player.play(SOUND_HANDS);
  // if (currentQuestion == 2) player.play(SOUND_MORNING);
  // if (currentQuestion == 3) player.play(SOUND_SLEEP);

  delay(7000);   // βάλε αρκετό χρόνο για να τελειώσει ΟΛΟ το ηχητικό

  clearStoredCards();

  state = SCANNING;
}

void clearStoredCards() {

  has1 = false;
  has2 = false;
  has3 = false;

  size1 = 0;
  size2 = 0;
  size3 = 0;
}

void scanReader(MFRC522 &reader, byte ssPin, byte storedUid[], byte &storedSize, bool &hasCard, byte ledPin, byte readerNum) {
  selectReader(ssPin);

  if (!reader.PICC_IsNewCardPresent()) {
    digitalWrite(ssPin, HIGH);
    return;
  }

  if (!reader.PICC_ReadCardSerial()) {
    digitalWrite(ssPin, HIGH);
    return;
  }

  storedSize = reader.uid.size;

  for (byte i = 0; i < storedSize; i++) {
    storedUid[i] = reader.uid.uidByte[i];
  }

  hasCard = true;
  //digitalWrite(ledPin, HIGH);

  Serial.print(F("R"));
  Serial.print(readerNum);
  Serial.print(F(" SAVED: "));
  printUid(storedUid, storedSize);

  // Δεν κάνουμε HaltA για να μη "κοιμίζουμε" τις NTAG κάρτες
  // reader.PICC_HaltA();
  // reader.PCD_StopCrypto1();

  digitalWrite(ssPin, HIGH);
  delay(20);
}

void checkCards() {
  Serial.println(F("CHECK"));

bool ok1 = compareUid(card1, size1, has1,
                      currentUIDs[0], currentSizes[0]);

bool ok2 = compareUid(card2, size2, has2,
                      currentUIDs[1], currentSizes[1]);

bool ok3 = compareUid(card3, size3, has3,
                      currentUIDs[2], currentSizes[2]);
  digitalWrite(LED1, ok1 ? HIGH : LOW);
  digitalWrite(LED2, ok2 ? HIGH : LOW);
  digitalWrite(LED3, ok3 ? HIGH : LOW);

  if (ok1 && ok2 && ok3) {
  showBitmap(epd_bitmap_success);
  //player.play(SOUND_SUCCESS);

  delay(2000);

  currentQuestion++;

  if (currentQuestion >= TOTAL_QUESTIONS) {
    currentQuestion = 0;
  }

  showBitmap(epd_bitmap_next);
  state = RESULT;
} else {
  showBitmap(epd_bitmap_tryagain);
 // player.play(SOUND_TRY_AGAIN);
  state = SCANNING;
}
}

bool compareUid(byte storedUid[], byte storedSize, bool hasCard, byte correctUid[], byte correctSize) {
  if (!hasCard) return false;
  if (storedSize != correctSize) return false;

  for (byte i = 0; i < correctSize; i++) {
    if (storedUid[i] != correctUid[i]) return false;
  }

  return true;
}

void selectReader(byte ssPin) {
  digitalWrite(SS1, HIGH);
  digitalWrite(SS2, HIGH);
  digitalWrite(SS3, HIGH);
  delay(3);
  digitalWrite(ssPin, LOW);
  delay(3);
}

void printUid(byte uid[], byte uidSize) {
  for (byte i = 0; i < uidSize; i++) {
    if (uid[i] < 0x10) Serial.print(F("0"));
    Serial.print(uid[i], HEX);
    if (i < uidSize - 1) Serial.print(F(":"));
  }
  Serial.println();
}

void showText(const char* line1, const char* line2) {
  u8g2.firstPage();
  do {
    u8g2.setFont(u8g2_font_6x10_tf);
    u8g2.drawStr(10, 24, line1);
    u8g2.drawStr(10, 46, line2);
  } while (u8g2.nextPage());
}

void showCurrentQuestion() {

  if (currentQuestion == 0) {

    showBitmap(epd_bitmap_teeth);

    currentUIDs[0] = teeth1;
    currentUIDs[1] = teeth2;
    currentUIDs[2] = teeth3;

    currentSizes[0] = 4;
    currentSizes[1] = 7;
    currentSizes[2] = 4;
  }

  else if (currentQuestion == 1) {

    showBitmap(epd_bitmap_hands);

    currentUIDs[0] = hands1;
    currentUIDs[1] = hands2;
    currentUIDs[2] = hands3;

    currentSizes[0] = 7;
    currentSizes[1] = 7;
    currentSizes[2] = 7;
  }

  else if (currentQuestion == 2) {

    showBitmap(epd_bitmap_morning);

    currentUIDs[0] = morning1;
    currentUIDs[1] = morning2;
    currentUIDs[2] = morning3;

    currentSizes[0] = 7;
    currentSizes[1] = 7;
    currentSizes[2] = 7;
  }

  else if (currentQuestion == 3) {

    showBitmap(epd_bitmap_sleep);

    currentUIDs[0] = sleep1;
    currentUIDs[1] = sleep2;
    currentUIDs[2] = sleep3;

    currentSizes[0] = 4;
    currentSizes[1] = 7;
    currentSizes[2] = 7;
  }
}
